# Application
APP_ENV=development
APP_PORT=8000

# Database
DB_DSN=postgres://us_user:us_secret@localhost:5432/urban_sanctuary?sslmode=disable
DB_MAX_CONNS=25

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# S3 / Cloudflare R2
S3_BUCKET=ubansanctuary
S3_REGION=us-east-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Payment Providers
MTN_MOMO_API_KEY=mtn-sandbox-key
MTN_MOMO_API_SECRET=mtn-sandbox-secret
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_CALLBACK_URL=http://localhost:8000/api/v1/webhooks/mtn
ORANGE_MONEY_API_KEY=orange-sandbox-key
ORANGE_MONEY_API_SECRET=orange-sandbox-secret
ORANGE_MONEY_BASE_URL=https://api.orange.com
ORANGE_MONEY_CALLBACK_URL=http://localhost:8000/api/v1/webhooks/orange

# SMTP Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=
SMTP_FROM=noreply@urbansanctuary.cm

# Africa's Talking SMS
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=UrbanSanc

# Observability
SENTRY_DSN=
OTEL_EXPORTER_ENDPOINT=localhost:4317

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
